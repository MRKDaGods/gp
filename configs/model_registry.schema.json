{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mtmc-tracker.local/schemas/model_registry.schema.json",
  "title": "MTMC Model Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "models"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "models": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/modelEntry" }
    }
  },
  "$defs": {
    "modelEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "task_type",
        "dataset",
        "description",
        "metrics",
        "pipeline_config",
        "model_overrides",
        "checkpoint_refs",
        "requirements",
        "status",
        "runnable_locally",
        "notebook_or_kernel_ref",
        "provenance",
        "tombstone"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "name": { "type": "string", "minLength": 1 },
        "task_type": {
          "type": "string",
          "enum": ["mtmc_vehicle", "mtmc_person", "single_cam_reid", "detector_only"]
        },
        "dataset": {
          "type": "string",
          "enum": ["cityflowv2", "wildtrack", "veri776", "custom"]
        },
        "description": { "type": "string", "minLength": 1 },
        "metrics": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/metric" }
        },
        "pipeline_config": {
          "type": ["string", "null"],
          "pattern": "^configs/.+\\.ya?ml$"
        },
        "model_overrides": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Za-z0-9_.]+=." }
        },
        "checkpoint_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/checkpointRef" }
        },
        "requirements": { "$ref": "#/$defs/requirements" },
        "status": {
          "type": "string",
          "enum": ["production", "research", "dead_end", "reference"]
        },
        "runnable_locally": { "type": "boolean" },
        "notebook_or_kernel_ref": { "type": ["string", "null"] },
        "provenance": { "$ref": "#/$defs/provenance" },
        "tombstone": {
          "anyOf": [
            { "$ref": "#/$defs/tombstone" },
            { "type": "null" }
          ]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "dead_end" } } },
          "then": { "properties": { "tombstone": { "$ref": "#/$defs/tombstone" } } },
          "else": { "properties": { "tombstone": { "type": "null" } } }
        }
      ]
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "value", "verified", "source", "note"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "value": { "type": "number" },
        "verified": { "type": "boolean" },
        "source": { "$ref": "#/$defs/metricSource" },
        "note": { "type": ["string", "null"] }
      }
    },
    "metricSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path", "kernel", "line_ref"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["kernel_summary", "local_json", "log_line", "docs"]
        },
        "path": { "type": "string", "minLength": 1 },
        "kernel": { "type": ["string", "null"] },
        "line_ref": { "type": ["string", "null"] }
      }
    },
    "checkpointRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "local_path",
        "expected_sha256",
        "hosted",
        "source_training_kernel",
        "size_bytes",
        "on_disk"
      ],
      "properties": {
        "role": {
          "type": "string",
          "enum": [
            "primary_reid",
            "secondary_reid",
            "tertiary_reid",
            "quaternary_reid",
            "detector",
            "tracker"
          ]
        },
        "local_path": { "type": "string", "minLength": 1 },
        "expected_sha256": { "type": ["string", "null"] },
        "hosted": {
          "type": "array",
          "items": { "$ref": "#/$defs/hostedCheckpoint" }
        },
        "source_training_kernel": { "type": ["string", "null"] },
        "size_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "on_disk": { "type": "boolean" }
      }
    },
    "hostedCheckpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kaggle_dataset", "member"],
      "properties": {
        "kaggle_dataset": { "type": "string", "minLength": 1 },
        "member": { "type": "string", "minLength": 1 }
      }
    },
    "requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gpu_required", "min_vram_gb", "data_dependencies"],
      "properties": {
        "gpu_required": { "type": "boolean" },
        "min_vram_gb": { "type": "integer", "minimum": 0 },
        "data_dependencies": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_at", "created_by_kernel", "verified_by"],
      "properties": {
        "created_at": { "type": "string", "format": "date" },
        "created_by_kernel": { "type": ["string", "null"] },
        "verified_by": { "type": "string", "minLength": 1 }
      }
    },
    "tombstone": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason", "superseded_by_id"],
      "properties": {
        "reason": { "type": "string", "minLength": 1 },
        "superseded_by_id": { "type": ["string", "null"] }
      }
    }
  }
}
